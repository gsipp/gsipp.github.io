VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  SECURITY WARNING — READ BEFORE ADDING KEYS
# -----------------------------------------------
# NEVER prefix the SERVICE_ROLE_KEY with VITE_
# Variables prefixed with VITE_ are bundled into the JS
# output and visible to anyone in the browser DevTools.
#
# The SERVICE_ROLE_KEY bypasses ALL Supabase RLS policies.
# It should ONLY be used in server-side environments (Node.js, Edge Functions).
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   ← Keep this WITHOUT the VITE_ prefix
#                                                      and use it ONLY in server contexts.
